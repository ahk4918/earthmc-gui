{
  "name": "earthmc-full-gui",
  "version": "1.0.0",
  "description": "Full desktop GUI client application for the EarthMC server ecosystem",
  "author": {
    "name": "Akhilesh G",
    "email": "akhilesh.gollapudi@outlook.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist:all": "electron-builder --linux --windows --mac",
    "dist:linux": "electron-builder --linux",
    "dist:windows": "electron-builder --windows",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.earthmc.gui",
    "productName": "EarthMC GUI",
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "renderer/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "identity": "-" 
    },
    "linux": {
      "target": [
        "dir",
        "deb",
        "rpm"
      ],
      "category": "Game",
      "maintainer": "Akhilesh G <akhilesh@example.com>"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs"
}
