{
  "name": "earthmc-full-gui",
  "version": "1.0.0",
  "description": "Full desktop GUI client application for the EarthMC server ecosystem",
  "homepage": "https://github.com/ahk4918/earthmc-gui",
  "author": {
    "name": "Akhilesh G",
    "email": "akhilesh.gollapudi@outlook.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist:all": "electron-builder --linux --windows",
    "dist:linux": "electron-builder --linux",
    "dist:windows": "electron-builder --windows",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.earthmc.gui",
    "productName": "EarthMC GUI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "renderer/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "ahk4918",
      "repo": "earthmc-gui"
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "dir"
      ],
      "category": "Game",
      "maintainer": "Akhilesh G <akhilesh@example.com>"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.games"
    }
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs"
}